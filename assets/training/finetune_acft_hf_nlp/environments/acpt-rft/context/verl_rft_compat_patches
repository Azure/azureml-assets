#!/usr/bin/env python3
"""verl RFT (GRPO) compatibility patches for the acft-rft-training image.

The image bundles components from several lineages (kernels, transformers, vLLM,
verl, flash-attn). This script applies a small set of idempotent, anchor-verified
source patches to the installed packages so the verl Reinforced Fine-Tuning (GRPO)
recipe runs end-to-end: model load, FSDP2, async vLLM agentic rollout, validation,
and the GRPO policy update.

Each patch locates its target by an exact source anchor and is safe to re-run; an
applied patch is detected and skipped. If an anchor is missing (e.g. a bundled
package version changed), the script fails loudly so the mismatch is visible at
image-build time rather than at job runtime.

Run inside the image's training conda env, e.g.:
    /opt/conda/envs/ptca/bin/python verl_rft_compat_patches.py
"""
import io
import os
import sys
import sysconfig

MARKER = "ACFT-RFT-COMPAT"


def _site_dirs():
    dirs = []
    for key in ("purelib", "platlib"):
        p = sysconfig.get_paths().get(key)
        if p and os.path.isdir(p) and p not in dirs:
            dirs.append(p)
    for p in sys.path:
        if p and p.endswith("site-packages") and os.path.isdir(p) and p not in dirs:
            dirs.append(p)
    return dirs


def _module_path(modname):
    # Resolve a module's source file by path WITHOUT importing it. Importing the target
    # packages (kernels / transformers / vllm / verl) during patching can load stale,
    # pre-patch code into memory and trigger import-time failures mid-build (e.g. a
    # find_spec that pulls in transformers -> kernels before its file is patched).
    rel = modname.replace(".", os.sep)
    for base in _site_dirs():
        cand = os.path.join(base, rel + ".py")
        if os.path.isfile(cand):
            return cand
        cand_init = os.path.join(base, rel, "__init__.py")
        if os.path.isfile(cand_init):
            return cand_init
    sys.exit(f"ERROR: could not locate source file for module {modname} in site-packages")


def _read(path):
    with io.open(path, "r", encoding="utf-8") as f:
        return f.read()


def _write(path, src):
    with io.open(path, "w", encoding="utf-8") as f:
        f.write(src)


def _replace(modname, old, new):
    """Replace an exact source anchor in a module's file (idempotent, all occurrences)."""
    path = _module_path(modname)
    src = _read(path)
    if MARKER in src and old not in src:
        print(f"[skip] already applied: {modname}")
        return
    if old not in src:
        sys.exit(
            f"ERROR: expected anchor not found in {path} ({modname}); "
            "the bundled package version may differ from the one this patch targets."
        )
    _write(path, src.replace(old, new))
    print(f"[ok]   patched: {modname}")


def _append(modname, block, *, require):
    """Append a block to a module's file once (idempotent)."""
    path = _module_path(modname)
    src = _read(path)
    if MARKER in src:
        print(f"[skip] already applied: {modname}")
        return
    if require not in src:
        sys.exit(
            f"ERROR: expected '{require}' not found in {path} ({modname}); "
            "the bundled package version may differ from the one this patch targets."
        )
    _write(path, src.rstrip("\n") + block)
    print(f"[ok]   patched: {modname}")


