# install is required). The recipe-supplied driver copy is enabled separately at submit time.
# --------------------------------------------------------------------------------------
_DRIVER_DASH_OLD = '''                    "--disable-usage-stats",
                    "--include-dashboard=false",
                ], stdout=subprocess.PIPE,'''
_DRIVER_DASH_NEW = '''                    "--disable-usage-stats",
                    # ACFT-RFT-COMPAT: start the Ray dashboard on port 8265.
                    "--include-dashboard=true",
                    "--dashboard-host=0.0.0.0",
                    "--dashboard-port=8265",
                ], stdout=subprocess.PIPE,'''

# Ray's dashboard reporter agent derives node boot time from PID 1 when it thinks it is in
# a Kubernetes pod, but PID 1 is not accessible in the Foundry/Singularity PID namespace,
# so the reporter loop crashes repeatedly. Fall back to host boot time when PID 1 is missing.
_RAY_REPORTER_OLD = '''        if IN_KUBERNETES_POD:
            # Return start time of container entrypoint
            return psutil.Process(pid=1).create_time()
        else:
            return psutil.boot_time()'''
_RAY_REPORTER_NEW = '''        if IN_KUBERNETES_POD:
            # Return start time of container entrypoint
            try:
                return psutil.Process(pid=1).create_time()
            except Exception:
                # ACFT-RFT-COMPAT: PID 1 is not accessible in some pods/containers
                # (Foundry / Singularity shared PID namespace); fall back to host boot time.
                return psutil.boot_time()
        else:
            return psutil.boot_time()'''


def _enable_bundled_driver_dashboard():
    import sysconfig
    roots = {p for p in (sysconfig.get_paths().get(k) for k in ("purelib", "platlib")) if p}
    found = False
    for root in roots:
        for dirpath, _dirs, files in os.walk(root):
            if "reasoning_train_rft.py" not in files:
                continue
            path = os.path.join(dirpath, "reasoning_train_rft.py")
            src = _read(path)
            if MARKER in src and _DRIVER_DASH_OLD not in src:
                print(f"[skip] already applied: {path}")
                found = True
                continue
            if _DRIVER_DASH_OLD in src:
                _write(path, src.replace(_DRIVER_DASH_OLD, _DRIVER_DASH_NEW, 1))
                print(f"[ok]   ray dashboard enabled in bundled driver: {path}")
                found = True
    if not found:
        print("[skip] no bundled reasoning_train_rft.py with the expected anchor found "
              "(recipe-supplied driver is patched at submit time)")


def main():
    _replace("kernels.layer.layer", _KERNELS_REPO_OLD, _KERNELS_REPO_NEW)
    _replace("kernels.layer.func", _KERNELS_REPO_OLD, _KERNELS_REPO_NEW)
    _replace("kernels._versions", _KERNELS_RESOLVER_OLD, _KERNELS_RESOLVER_NEW)

    # vLLM <-> flash-attn 4 / transformers FA integration
    _replace("vllm.model_executor.layers.rotary_embedding.common", _VLLM_ROTARY_OLD, _VLLM_ROTARY_NEW)
    _replace("transformers.integrations.flash_attention", _TF_SAUX_OLD, _TF_SAUX_NEW)

    # verl 0.7.1 worker layer <-> vendored post-0.8.0 vLLM rollout
    _append("verl.workers.rollout.utils", _VERL_UTILS_APPEND, require=_VERL_UTILS_REQUIRE)
    _replace("verl.workers.rollout.vllm_rollout", _VERL_INIT_OLD, _VERL_INIT_NEW)
    _replace("verl.workers.rollout.base", _VERL_REGISTRY_OLD, _VERL_REGISTRY_NEW)
    _replace("verl.utils.fsdp_utils", _VERL_FSDP2_OLD, _VERL_FSDP2_NEW)
    _replace("verl.workers.rollout.vllm_rollout.vllm_rollout", _VERL_DISPATCH_OLD, _VERL_DISPATCH_NEW)

    # verl async worker server-mode methods (two anchors in one file)
    fsdp_workers_path = _module_path("verl.workers.fsdp_workers")
    src = _read(fsdp_workers_path)
    if MARKER in src:
        print("[skip] already applied: verl.workers.fsdp_workers")
    else:
        for anchor, new in ((_VERL_TRAINER_OLD, _VERL_TRAINER_NEW), (_VERL_ASYNC_OLD, _VERL_ASYNC_NEW)):
            if anchor not in src:
                sys.exit(
                    f"ERROR: expected anchor not found in {fsdp_workers_path} "
                    "(verl.workers.fsdp_workers); the bundled verl may differ."
                )
            src = src.replace(anchor, new, 1)
        _write(fsdp_workers_path, src)
        print("[ok]   patched: verl.workers.fsdp_workers")

    # verl actor forward <-> flash-attn 4 / activation offload
    _replace("verl.utils.attention_utils", _VERL_BERT_OLD, _VERL_BERT_NEW)
    _replace("verl.workers.actor.dp_actor", _VERL_LOGITS_OLD, _VERL_LOGITS_NEW)

    # Ray dashboard: reporter robustness + enable it on :8265
    _replace("ray.dashboard.modules.reporter.reporter_agent", _RAY_REPORTER_OLD, _RAY_REPORTER_NEW)
    _enable_bundled_driver_dashboard()

    print("All verl RFT (GRPO) compatibility patches applied.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
