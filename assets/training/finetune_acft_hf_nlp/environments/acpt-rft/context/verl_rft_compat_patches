# --------------------------------------------------------------------------------------
# With activation offload enabled, the actor's logits are returned as-is by a custom
# autograd Function, so the squeezed view cannot be scaled in-place. Scale out-of-place.
# --------------------------------------------------------------------------------------
_VERL_LOGITS_OLD = '''                    logits_rmpad = output.logits.squeeze(0)  # (total_nnz, vocab_size)
                    logits_rmpad.div_(temperature)'''
_VERL_LOGITS_NEW = '''                    logits_rmpad = output.logits.squeeze(0)  # (total_nnz, vocab_size)
                    # ACFT-RFT-COMPAT: out-of-place scaling. With activation offload, output.logits
                    # is returned as-is by a custom autograd Function, so the squeeze(0) view cannot
                    # be modified in-place (div_). Produce a fresh tensor instead.
                    logits_rmpad = logits_rmpad / temperature'''


